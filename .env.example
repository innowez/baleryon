# Phone OTP / SMS delivery (Twilio)
# When these are set, OTP codes are sent over SMS via Twilio.
# When unset in development, the code is printed to the SERVER console only
# (never returned to the browser). In production, requesting an OTP without
# these configured returns an error instead of leaking the code.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Use a Twilio phone number in E.164 format, e.g. +15555550100
TWILIO_FROM_NUMBER=
# Optional: prefer a Messaging Service SID over a single from-number.
# When set, this takes precedence over TWILIO_FROM_NUMBER.
TWILIO_MESSAGING_SERVICE_SID=

# Secret used to sign auth tokens. Set a strong random value in production.
JWT_SECRET=

# Optional: point the client at an external backend instead of the built-in
# Next.js API routes.
NEXT_PUBLIC_API_URL=
