// Baleryon E-Commerce — PostgreSQL schema (PERN stack)
// Run: npx prisma migrate dev | npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum AuthProvider {
  local
  google
  facebook
  phone
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum InventoryLogType {
  PURCHASE
  SALE
  RETURN
  DAMAGE
  ADJUSTMENT
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  REFUNDED
  COMPLETED
}

enum AnalyticsEventName {
  PRODUCT_VIEW
  ADD_TO_CART
  REMOVE_CART
  CHECKOUT_STARTED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
}

enum JoinCommunityStatus {
  ADDED
  PENDING
  INVALID
  VALID
}

// ─── 1. Users & Roles ──────────────────────────────────────────────────────

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  users User[]

  @@map("roles")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  fullName     String       @map("full_name") @db.VarChar(150)
  email        String       @unique @db.VarChar(150)
  phone        String?      @unique @db.VarChar(20)
  passwordHash String?      @map("password_hash")
  profileImage String?      @map("profile_image")
  provider     AuthProvider @default(local)
  providerId   String?      @map("provider_id")
  roleId       String?      @map("role_id") @db.Uuid
  isVerified   Boolean      @default(false) @map("is_verified")
  isBlocked    Boolean      @default(false) @map("is_blocked")
  lastLogin    DateTime?    @map("last_login")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  role            Role?            @relation(fields: [roleId], references: [id])
  addresses       Address[]
  carts           Cart[]
  wishlists       Wishlist[]
  orders          Order[]
  reviews         Review[]
  notifications   Notification[]
  analyticsEvents AnalyticsEvent[]

  @@map("users")
}

// ─── 2. Addresses ──────────────────────────────────────────────────────────

model Address {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  fullName     String?  @map("full_name") @db.VarChar(150)
  phone        String?  @db.VarChar(20)
  addressLine1 String   @map("address_line_1")
  addressLine2 String?  @map("address_line_2")
  landmark     String?
  city         String?  @db.VarChar(100)
  state        String?  @db.VarChar(100)
  country      String?  @db.VarChar(100)
  postalCode   String?  @map("postal_code") @db.VarChar(20)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ─── 3. Categories & Brands ──────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(120)
  image     String?
  parentId  String?  @map("parent_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@map("categories")
}

model Brand {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(120)
  logo      String?
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("brands")
}

// ─── 4. Products, Variants & Images ──────────────────────────────────────────

model Product {
  id               String   @id @default(uuid()) @db.Uuid
  categoryId       String?  @map("category_id") @db.Uuid
  brandId          String?  @map("brand_id") @db.Uuid
  title            String   @db.VarChar(255)
  slug             String   @unique @db.VarChar(255)
  shortDescription String?  @map("short_description")
  description      String?
  fabric           String?  @db.VarChar(100)
  fit              String?  @db.VarChar(50)
  gender           String?  @db.VarChar(20)
  basePrice        Decimal  @map("base_price") @db.Decimal(10, 2)
  salePrice        Decimal? @map("sale_price") @db.Decimal(10, 2)
  costPrice        Decimal? @map("cost_price") @db.Decimal(10, 2)
  isFeatured       Boolean  @default(false) @map("is_featured")
  isActive         Boolean  @default(true) @map("is_active")
  seoTitle         String?  @map("seo_title")
  seoDescription   String?  @map("seo_description")
  discountPercent  Decimal? @map("discount_percent") @db.Decimal(5, 2)
  note             String?
  isReturnable     Boolean  @default(false) @map("is_returnable")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  category   Category?        @relation(fields: [categoryId], references: [id])
  brand      Brand?           @relation(fields: [brandId], references: [id])
  variants   ProductVariant[]
  images     ProductImage[]
  wishlists  Wishlist[]
  reviews    Review[]
  orderItems OrderItem[]

  @@index([slug])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  sku       String   @unique @db.VarChar(100)
  color     String?  @db.VarChar(50)
  colorHex  String?  @map("color_hex") @db.VarChar(7)
  size      String?  @db.VarChar(20)
  stock     Int      @default(0)
  price     Decimal? @db.Decimal(10, 2)
  salePrice Decimal? @map("sale_price") @db.Decimal(10, 2)
  weight    Decimal? @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  images        ProductImage[]
  inventoryLogs InventoryLog[]
  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid
  imageUrl  String  @map("image_url")
  altText   String? @map("alt_text")
  isPrimary Boolean @default(false) @map("is_primary")
  sortOrder Int     @default(0) @map("sort_order")

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("product_images")
}

// ─── 5. Inventory ────────────────────────────────────────────────────────────

model InventoryLog {
  id        String           @id @default(uuid()) @db.Uuid
  variantId String           @map("variant_id") @db.Uuid
  quantity  Int
  type      InventoryLogType
  note      String?
  createdAt DateTime         @default(now()) @map("created_at")

  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("inventory_logs")
}

// ─── 6. Cart & Wishlist ──────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id])
  items CartItem[]

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid()) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@map("cart_items")
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("wishlists")
}

// ─── 7. Orders & Items ───────────────────────────────────────────────────────

model Order {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  orderNumber    String        @unique @map("order_number") @db.VarChar(50)
  addressId      String?       @map("address_id") @db.Uuid
  subtotal       Decimal?      @db.Decimal(10, 2)
  discountAmount Decimal?      @map("discount_amount") @db.Decimal(10, 2)
  shippingAmount Decimal?      @map("shipping_amount") @db.Decimal(10, 2)
  totalAmount    Decimal?      @map("total_amount") @db.Decimal(10, 2)
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  orderStatus    OrderStatus   @default(PENDING) @map("order_status")
  paymentMethod  String?       @map("payment_method") @db.VarChar(50)
  notes          String?
  placedAt       DateTime      @default(now()) @map("placed_at")

  user      User        @relation(fields: [userId], references: [id])
  address   Address?    @relation(fields: [addressId], references: [id])
  items     OrderItem[]
  payments  Payment[]
  shipments Shipment[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @map("order_id") @db.Uuid
  productId   String? @map("product_id") @db.Uuid
  variantId   String? @map("variant_id") @db.Uuid
  productName String? @map("product_name") @db.VarChar(255)
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(10, 2)

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  returns OrderReturn[]

  @@map("order_items")
}

// ─── 8. Payments ─────────────────────────────────────────────────────────────

model Payment {
  id             String        @id @default(uuid()) @db.Uuid
  orderId        String        @map("order_id") @db.Uuid
  paymentGateway String?       @map("payment_gateway") @db.VarChar(50)
  transactionId  String?       @map("transaction_id")
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  amount         Decimal?      @db.Decimal(10, 2)
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("payments")
}

// ─── 9. Coupons ──────────────────────────────────────────────────────────────

model Coupon {
  id           String     @id @default(uuid()) @db.Uuid
  code         String     @unique @db.VarChar(50)
  type         CouponType
  value        Decimal    @db.Decimal(10, 2)
  minimumOrder Decimal?   @map("minimum_order") @db.Decimal(10, 2)
  usageLimit   Int?       @map("usage_limit")
  usedCount    Int        @default(0) @map("used_count")
  startsAt     DateTime?  @map("starts_at")
  expiresAt    DateTime?  @map("expires_at")
  isActive     Boolean    @default(true) @map("is_active")

  @@map("coupons")
}

// ─── 10. Reviews ─────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  rating    Int
  review    String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("reviews")
}

// ─── 11. Shipping ────────────────────────────────────────────────────────────

model Shipment {
  id             String    @id @default(uuid()) @db.Uuid
  orderId        String    @map("order_id") @db.Uuid
  courierName    String?   @map("courier_name") @db.VarChar(100)
  trackingNumber String?   @map("tracking_number")
  trackingUrl    String?   @map("tracking_url")
  shippedAt      DateTime? @map("shipped_at")
  deliveredAt    DateTime? @map("delivered_at")

  order Order @relation(fields: [orderId], references: [id])

  @@map("shipments")
}

// ─── 12. Returns & Refunds ───────────────────────────────────────────────────

model OrderReturn {
  id           String       @id @default(uuid()) @db.Uuid
  orderItemId  String       @map("order_item_id") @db.Uuid
  reason       String?
  status       ReturnStatus @default(REQUESTED)
  refundAmount Decimal?     @map("refund_amount") @db.Decimal(10, 2)
  createdAt    DateTime     @default(now()) @map("created_at")

  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("returns")
}

// ─── 13. Notifications ───────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String?
  message   String?
  type      String?  @db.VarChar(50)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─── 14. CMS / Landing Page ──────────────────────────────────────────────────

model Banner {
  id          String   @id @default(uuid()) @db.Uuid
  imageUrl    String?  @map("image_url")
  topContent  String?  @map("top_content") @db.Text
  mainContent String?  @map("main_content") @db.Text
  lastContent String?  @map("last_content") @db.Text
  shopNowLink String?  @map("shop_now_link") @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("banners")
}

model LimitedSeason {
  id                 String   @id @default(uuid()) @db.Uuid
  mainContent        String?  @map("main_content") @db.Text
  description        String?  @db.Text
  timeCountingHours  Int      @default(3) @map("time_counting_hours")
  ctaLink            String?  @map("cta_link") @db.VarChar(500)
  backgroundImageUrl String?  @map("background_image_url")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("limited_seasons")
}

model UrbanStory {
  id        String   @id @default(uuid()) @db.Uuid
  category  String   @db.VarChar(255)
  ctaLink   String?  @map("cta_link") @db.VarChar(500)
  imageUrl  String?  @map("image_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("urban_stories")
}

model JoinCommunity {
  id        String              @id @default(uuid()) @db.Uuid
  email     String              @unique @db.VarChar(255)
  status    JoinCommunityStatus @default(ADDED)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@map("join_community")
}

// ─── 15. SEO ─────────────────────────────────────────────────────────────────

model SeoPage {
  id              String  @id @default(uuid()) @db.Uuid
  pageSlug        String  @unique @map("page_slug") @db.VarChar(255)
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")
  ogImage         String? @map("og_image")

  @@map("seo_pages")
}

// ─── 16. Analytics ───────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String?            @map("user_id") @db.Uuid
  eventName AnalyticsEventName @map("event_name")
  metadata  Json?
  createdAt DateTime           @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("analytics_events")
}
